---
import type { TourRoute } from '../data/routes';
interface Props { route: TourRoute; }
const { route } = Astro.props;
const base = import.meta.env.BASE_URL;
const image = `${base}${route.image.replace(/^\//, '')}`;
---
<article class="route-card">
  <a class="route-card-image" href={`${base}rutas/${route.slug}/`} aria-label={`Ver ${route.title}`}>
    <img src={image} alt={route.imageAlt} loading="lazy" />
    <span class:list={['status-pill', route.status]}>{route.statusLabel}</span>
  </a>
  <div class="route-card-body">
    <p class="eyebrow">{route.eyebrow}</p>
    <h2><a href={`${base}rutas/${route.slug}/`}>{route.title}</a></h2>
    <p>{route.promise}</p>
    <dl class="route-facts">
      <div><dt>Duración</dt><dd>{route.duration}</dd></div>
      <div><dt>Zona</dt><dd>{route.area}</dd></div>
    </dl>
    <div class="card-actions">
      <a class="text-link" href={`${base}rutas/${route.slug}/`}>Ver la ruta <span aria-hidden="true">→</span></a>
      <label class="compare-check"><input type="checkbox" value={route.slug} data-compare-check /> Comparar</label>
    </div>
  </div>
</article>
