---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublicRoutes } from '../lib/public-routes';
const bookableRoutes = (await getPublicRoutes()).filter((route) => route.status === 'available');
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="Reservar una ruta" description="Reserva una ruta de Rutas B eligiendo una fecha y uno de sus horarios disponibles.">
  <header class="page-hero compact"><div><p class="kicker">Reserva sin pago en esta etapa</p><h1>Reserva tu ruta</h1><p>Elige la fecha y el horario. Las horas disponibles cambian automáticamente según el día del calendario.</p></div></header>
  <section class="section form-section">
    <form class="booking-form" data-booking-form data-base={base} novalidate>
      <div class="form-progress" aria-label="Progreso"><span class="active">1. Ruta</span><span>2. Contacto</span><span>3. Reserva</span></div>
      <div class="form-message" data-form-message role="alert" hidden></div>
      <fieldset><legend>Elige la experiencia</legend><div class="form-grid">
        <label class="field full"><span>Ruta</span><select name="route" required><option value="">Selecciona una ruta</option>{bookableRoutes.map((r) => <option value={r.slug}>{r.title}</option>)}</select><small data-error-for="route"></small></label>
        <label class="field"><span>Fecha</span><input name="date" type="date" required /><small data-error-for="date"></small></label>
        <label class="field"><span>Hora</span><select name="time" required disabled><option value="">Selecciona primero una fecha</option></select><small data-time-help>De lunes a viernes: 18:00 y 22:00. Fines de semana: 10:00, 12:00, 18:00 y 22:00.</small><small data-error-for="time"></small></label>
        <label class="field"><span>Idioma</span><select name="language" required><option value="">Selecciona</option><option value="es">Español</option><option value="en">English</option></select><small data-error-for="language"></small></label>
        <label class="field"><span>Número de personas</span><input name="people" type="number" min="1" max="50" inputmode="numeric" required /><small data-error-for="people"></small></label>
        <label class="field full"><span>Modalidad</span><select name="modality" required><option value="">Selecciona</option><option value="shared">Individual / compartida, si está disponible</option><option value="private">Grupo privado</option><option value="partner">Hotel, agencia o partner</option></select><small data-error-for="modality"></small></label>
      </div></fieldset>
      <fieldset><legend>Datos de contacto</legend><div class="form-grid">
        <label class="field"><span>Nombre y apellido</span><input name="name" autocomplete="name" required /><small data-error-for="name"></small></label>
        <label class="field"><span>Correo electrónico</span><input name="email" type="email" autocomplete="email" required /><small data-error-for="email"></small></label>
        <label class="field full"><span>Teléfono <em>opcional</em></span><input name="phone" type="tel" autocomplete="tel" /></label>
        <label class="field full"><span>Solicitud especial <em>opcional</em></span><textarea name="notes" rows="4" maxlength="1000" placeholder="Cuéntanos si hay necesidades de movilidad, edades del grupo o un contexto especial."></textarea><small class="character-count">Máximo 1.000 caracteres</small></label>
      </div></fieldset>
      <label class="honeypot" aria-hidden="true">Sitio web<input name="website" tabindex="-1" autocomplete="off" /></label>
      <label class="consent"><input name="privacy" type="checkbox" required /><span>He leído la <a href={`${base}privacidad/`} target="_blank">política de privacidad</a> y autorizo el uso de estos datos para gestionar mi reserva.</span></label><small data-error-for="privacy"></small>
      <div class="form-summary"><strong>Tu reserva</strong><p>Al enviar el formulario, la reserva quedará registrada. Recibirás por correo la referencia, el horario elegido y el punto de encuentro.</p></div>
      <button class="button primary submit-button" type="submit">Reservar ruta</button>
    </form>
  </section>
  <script src="../scripts/booking-form.ts"></script>
</BaseLayout>
