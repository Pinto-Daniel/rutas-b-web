---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublicRoutes } from '../lib/public-routes';
const publishedRoutes = await getPublicRoutes();
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="Comparar rutas" description="Compara duración, zona, formato e idiomas de las rutas de Rutas B.">
  <header class="page-hero compact"><div><p class="kicker">Decide con claridad</p><h1>Compara las rutas</h1><p>La comparación muestra solo información confirmada. Lo que aún falta aparece como pendiente.</p></div></header>
  <section class="section compare-section">
    <div class="compare-scroll"><table class="compare-table"><thead><tr><th scope="col">Característica</th>{publishedRoutes.map((route) => <th scope="col">{route.title}<small>{route.statusLabel}</small></th>)}</tr></thead><tbody>
      <tr><th scope="row">Zona</th>{publishedRoutes.map((r) => <td>{r.area}</td>)}</tr><tr><th scope="row">Duración</th>{publishedRoutes.map((r) => <td>{r.duration}</td>)}</tr><tr><th scope="row">Formato</th>{publishedRoutes.map((r) => <td>{r.format}</td>)}</tr><tr><th scope="row">Idiomas</th>{publishedRoutes.map((r) => <td>{r.languages.join(' · ')}</td>)}</tr><tr><th scope="row">Precio individual</th>{publishedRoutes.map((r) => <td>{r.priceIndividual}</td>)}</tr><tr><th scope="row">Grupo privado</th>{publishedRoutes.map((r) => <td>{r.priceGroup}</td>)}</tr><tr><th scope="row">Acción</th>{publishedRoutes.map((r) => <td><a class="text-link" href={`${base}rutas/${r.slug}/`}>Ver ficha →</a></td>)}</tr>
    </tbody></table></div>
  </section>
</BaseLayout>
